# Frontend Dockerfile for Production
# Build stage
FROM node:24-alpine AS build

# Accept build arguments
ARG VITE_API_URL=/api

WORKDIR /app

# Install pnpm
RUN npm install -g pnpm

# Copy workspace files
COPY pnpm-lock.yaml pnpm-workspace.yaml package.json .pnpmrc* ./
COPY frontend/package.json ./frontend/

# Install dependencies for frontend workspace only
RUN --mount=type=cache,id=pnpm,target=/root/.local/share/pnpm/store \
    pnpm install --frozen-lockfile --filter alfajr --ignore-scripts

# Rebuild esbuild binary (needed by vite build)
RUN pnpm --filter alfajr rebuild esbuild

# Copy frontend source code
COPY frontend/ ./frontend/

# Set working directory to frontend
WORKDIR /app/frontend

# Create .env file with VITE_API_URL for build
RUN echo "VITE_API_URL=${VITE_API_URL}" > .env

# Build application
RUN pnpm run build

# Verify build output
RUN if [ -d dist ]; then ls -la dist; else echo "ERROR: build output not found (dist/)" >&2; exit 1; fi

# Production stage
FROM nginx:alpine

# Copy built assets from build stage
COPY --from=build /app/frontend/dist /usr/share/nginx/html

# Copy nginx configuration
COPY --from=build /app/frontend/nginx.conf /etc/nginx/conf.d/default.conf

# Expose port
EXPOSE 80

# Start nginx
CMD ["nginx", "-g", "daemon off;"]
